<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Habit_Tracker.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:Habit_Tracker.Models"
        xmlns:conv="using:Habit_Tracker.Converters"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="Habit_Tracker.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Habit Tracker"
        Width="600" Height="500"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToDoneConverter x:Key="BoolToDoneConverter"/>
        <conv:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="Habit Tracker" 
                       FontSize="32" 
                       FontWeight="ExtraBold" 
                       Foreground="#2196F3"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Consistency is key!" 
                       FontSize="14" 
                       FontStyle="Italic" 
                       Foreground="Gray"
                       HorizontalAlignment="Center"/>
            <Separator Margin="0,15"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" 
                    Orientation="Vertical" 
                    Spacing="10" 
                    Margin="0,20,0,0">
            <TextBox Watermark="Habit Name" Text="{Binding NewHabitName}"/>
            <TextBox Watermark="Description" Text="{Binding NewHabitDescription}"/>
            <Button Content="Add New Habit" 
                    Command="{Binding AddHabitCommand}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="10,5"
                    Background="#2196F3"
                    Foreground="White"/>
        </StackPanel>

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Habits}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:Habit">
                        <Border BorderBrush="#DDDDDD" 
                                BorderThickness="1" 
                                CornerRadius="5" 
                                Padding="15" 
                                Margin="0,0,0,10">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="5">
                                    <Button Content="{Binding IsCompletedToday, Converter={StaticResource BoolToDoneConverter}}" 
                                            Background="{Binding IsCompletedToday, Converter={StaticResource BoolToColorConverter}}" 
                                            Foreground="White"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleDoneCommand}"
                                            CommandParameter="{Binding Id}"/>
                                    <Button Content="Delete" 
                                            Background="#F44336" 
                                            Foreground="White"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteHabitCommand}"
                                            CommandParameter="{Binding Id}"/>
                                </StackPanel>
                                
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="18"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="Gray" Margin="0,0,0,5"/>
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <TextBlock Text="{Binding CurrentStreak, StringFormat='🔥 Current: {0}'}" FontSize="12" Foreground="OrangeRed" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding BestStreak, StringFormat='🏆 Best: {0}'}" FontSize="12" Foreground="Goldenrod" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TotalCompleted, StringFormat='✅ Total: {0}'}" FontSize="12" Foreground="DodgerBlue" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
