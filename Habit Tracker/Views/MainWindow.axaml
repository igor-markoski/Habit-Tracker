<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Habit_Tracker.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:Habit_Tracker.Models"
        xmlns:conv="using:Habit_Tracker.Converters"
        mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="600"
        x:Class="Habit_Tracker.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Habit Tracker"
        Width="700" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SystemRegionBrush}">

    <Window.Resources>
        <conv:BoolToDoneConverter x:Key="BoolToDoneConverter"/>
        <conv:BoolToColorConverter x:Key="BoolToColorConverter"/>
    </Window.Resources>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}"/>
        <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}"/>
    </Window.KeyBindings>

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource SystemChromeLowColor}"
                Padding="20"
                BorderBrush="{DynamicResource SystemBaseLowColor}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Habit Tracker"
                               FontSize="28"
                               FontWeight="ExtraBold"
                               Foreground="#2196F3"/>
                    <TextBlock Text="Consistency is key!"
                               FontSize="14"
                               Foreground="Gray"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Content="↶"
                            ToolTip.Tip="{Binding History.UndoLabel}"
                            Command="{Binding UndoCommand}"
                            IsEnabled="{Binding History.CanUndo}"
                            Background="Transparent"
                            FontSize="16"
                            Padding="10,8"
                            CornerRadius="5"/>
                    <Button Content="↷"
                            ToolTip.Tip="{Binding History.RedoLabel}"
                            Command="{Binding RedoCommand}"
                            IsEnabled="{Binding History.CanRedo}"
                            Background="Transparent"
                            FontSize="16"
                            Padding="10,8"
                            CornerRadius="5"/>
                    <Button Content="+ Add Habit"
                            Command="{Binding AddHabitCommand}"
                            Background="#2196F3"
                            Foreground="White"
                            FontWeight="Bold"
                            Padding="15,10"
                            CornerRadius="5"/>
                    <Button Content="🌓 Theme"
                            Command="{Binding ToggleThemeCommand}"
                            Background="Transparent"
                            Padding="10"
                            CornerRadius="5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <ItemsControl ItemsSource="{Binding Habits}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:Habit">
                        <Border Background="{DynamicResource SystemAltHighColor}"
                                BorderBrush="{DynamicResource SystemBaseLowColor}" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Padding="20" 
                                Margin="0,0,0,15">
                            <Grid ColumnDefinitions="*, Auto">
                                <!-- Info -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="20" Margin="0,0,0,5"/>
                                    <TextBlock Text="{Binding Description}" FontSize="14" Foreground="Gray" Margin="0,0,0,15"/>
                                    
                                    <!-- Stats Grid -->
                                    <StackPanel Orientation="Horizontal" Spacing="25">
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="🔥" FontSize="16"/>
                                            <TextBlock Text="{Binding CurrentStreak, StringFormat='Streak: {0}'}" FontSize="14" Foreground="OrangeRed" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="🏆" FontSize="16"/>
                                            <TextBlock Text="{Binding BestStreak, StringFormat='Best: {0}'}" FontSize="14" Foreground="Goldenrod" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                            <TextBlock Text="✅" FontSize="16"/>
                                            <TextBlock Text="{Binding TotalCompleted, StringFormat='Total: {0}'}" FontSize="14" Foreground="DodgerBlue" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                
                                <!-- Actions -->
                                <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="10" VerticalAlignment="Center" Margin="20,0,0,0">
                                    <Button Content="{Binding IsCompletedToday, Converter={StaticResource BoolToDoneConverter}}" 
                                            Background="{Binding IsCompletedToday, Converter={StaticResource BoolToColorConverter}}" 
                                            Foreground="White"
                                            FontWeight="Bold"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="20,10"
                                            CornerRadius="5"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ToggleDoneCommand}"
                                            CommandParameter="{Binding Id}"/>
                                    <Button Content="Delete" 
                                            Background="Transparent" 
                                            Foreground="#F44336"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteHabitCommand}"
                                            CommandParameter="{Binding Id}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
